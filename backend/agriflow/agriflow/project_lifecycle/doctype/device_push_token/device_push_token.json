{
  "doctype": "DocType",
  "name": "Device Push Token",
  "module": "Project Lifecycle",
  "custom": 1,
  "autoname": "hash",
  "engine": "InnoDB",
  "field_order": ["device_id", "user", "platform", "push_token", "app_version", "is_active", "last_seen"],
  "fields": [
    {"fieldname": "device_id", "fieldtype": "Data", "label": "Device ID", "reqd": 1, "in_list_view": 1},
    {"fieldname": "user", "fieldtype": "Link", "label": "User", "options": "User", "reqd": 1, "in_list_view": 1},
    {"fieldname": "platform", "fieldtype": "Data", "label": "Platform", "in_list_view": 1},
    {"fieldname": "push_token", "fieldtype": "Data", "label": "Push Token", "reqd": 1},
    {"fieldname": "app_version", "fieldtype": "Data", "label": "App Version"},
    {"fieldname": "is_active", "fieldtype": "Check", "label": "Active", "default": "1"},
    {"fieldname": "last_seen", "fieldtype": "Datetime", "label": "Last Seen", "reqd": 1, "in_list_view": 1}
  ],
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "Field Staff", "read": 0, "write": 0, "create": 1, "delete": 0}
  ]
}
