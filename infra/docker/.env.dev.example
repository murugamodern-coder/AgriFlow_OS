# AgriFlow OS — local development environment variables
# Copy to .env.dev (same directory as docker-compose.dev.yml):
#   cp .env.dev.example .env.dev
#
# Used with:
#   docker compose --env-file .env.dev -f docker-compose.dev.yml up -d

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
TZ=Asia/Kolkata

# -----------------------------------------------------------------------------
# MariaDB 11
# -----------------------------------------------------------------------------
MARIADB_ROOT_PASSWORD=change-me-root
MARIADB_DATABASE=agriflow
MARIADB_USER=agriflow
MARIADB_PASSWORD=change-me-agriflow
MARIADB_PUBLISH_PORT=3306

# Host connection (for Frappe bench on host, when added):
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=agriflow
# DB_USER=agriflow
# DB_PASSWORD=change-me-agriflow

# -----------------------------------------------------------------------------
# Redis 7
# -----------------------------------------------------------------------------
# Leave empty for no password in local dev; set for auth-enabled testing.
REDIS_PASSWORD=
REDIS_PUBLISH_PORT=6379

# REDIS_URL=redis://127.0.0.1:6379/0
# REDIS_URL=redis://:password@127.0.0.1:6379/0

# -----------------------------------------------------------------------------
# MinIO
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=agriflow-minio
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_BUCKET=agriflow-dev
MINIO_BROWSER=on
MINIO_API_PUBLISH_PORT=9000
MINIO_CONSOLE_PUBLISH_PORT=9001

# MINIO_ENDPOINT=http://127.0.0.1:9000
# Console: http://127.0.0.1:9001

# -----------------------------------------------------------------------------
# Future Frappe (placeholders)
# -----------------------------------------------------------------------------
# FRAPPE_HTTP_PUBLISH_PORT=8000
# SITE_NAME=agriflow.local
