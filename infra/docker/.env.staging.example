# Copy to .env.staging on the VPS — NEVER commit real secrets.
# Generate: bash infra/scripts/generate_secrets.sh staging

# --- Domain (public staging) ---
STAGING_DOMAIN=staging.example.com
FRAPPE_SITE=staging.example.com
BENCH_PATH=/home/deploy/workspace/frappe-bench

# --- MariaDB (Docker volume mariadb_staging) ---
MARIADB_ROOT_PASSWORD=CHANGE_ME
MARIADB_DATABASE=agriflow_staging
MARIADB_USER=agriflow
MARIADB_PASSWORD=CHANGE_ME
# Host bench connects via published port (127.0.0.1 only)
MARIADB_PUBLISH_HOST=127.0.0.1
MARIADB_PUBLISH_PORT=3307

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME
REDIS_PUBLISH_PORT=6380

# --- MinIO (S3-compatible attachments) ---
MINIO_ROOT_USER=agriflow
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_PUBLISH_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- nginx / TLS ---
HTTP_PUBLISH_PORT=80
HTTPS_PUBLISH_PORT=443
TLS_CERT_DIR=./nginx/certs
# Upstream Frappe bench on host
FRAPPE_UPSTREAM_HOST=host.docker.internal
FRAPPE_UPSTREAM_PORT=8000

# --- AgriFlow app ---
AGRIFLOW_MIN_APP_VERSION=0.24.0
AGRIFLOW_ROLLOUT_WAVE=staging
AGRIFLOW_FCM_SERVER_KEY=simulate
TZ=Asia/Kolkata

# --- Backup ---
BACKUP_DIR=/var/backups/agriflow
BACKUP_RETENTION_DAYS=14
