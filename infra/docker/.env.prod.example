# AgriFlow production-shaped compose — copy to .env.prod
TZ=Asia/Kolkata
MARIADB_ROOT_PASSWORD=change-me-root
MARIADB_DATABASE=agriflow
MARIADB_USER=agriflow
MARIADB_PASSWORD=change-me-db
REDIS_PASSWORD=change-me-redis
MINIO_ROOT_USER=agriflow
MINIO_ROOT_PASSWORD=change-me-minio
HTTP_PUBLISH_PORT=8080

# Site / bench (host or container)
AGRIFLOW_JWT_SECRET=change-me-jwt-secret-min-32-chars
AGRIFLOW_AUTH_MODE=jwt
